CORS_ORIGINS=*

# ===============================
# LLM Provider Selection
# ===============================
# Options: "openai" or "gemini"
LLM_PROVIDER="openai"

# -------------------------------
# OpenAI Configuration
# -------------------------------
OPENAI_API_KEY=

OPENAI_MODEL_ADVANCED="gpt-4o"
OPENAI_MODEL_MEDIUM="gpt-4o-mini"
OPENAI_MODEL_BASIC="gpt-4o-mini"

OPENAI_MODEL_NAME="gpt-4o-mini"

# -------------------------------
# Gemini Configuration
# -------------------------------
GEMINI_API_KEY=

# Gemini model options (all supported with langchain-google-genai 4.2.1+):
# - gemini-2.0-flash-exp: Fast, experimental model (stable for tool calling)
# - gemini-1.5-pro: Stable production model with excellent reasoning
# - gemini-1.5-flash: Fast, stable model for simple tasks
# - gemini-2.5-flash-exp: Experimental with advanced features
# - gemini-3.0-flash: Latest model with advanced reasoning (thought_signature supported)
# - gemini-3.1-flash: Latest model with advanced reasoning (thought_signature supported)
#
# NOTE: With langchain-google-genai 4.2.1+, thought_signature is automatically preserved
# for all Gemini models. The custom_agent.py handles provider-aware message filtering.

GEMINI_MODEL_ADVANCED="gemini-2.0-flash-exp"
GEMINI_MODEL_MEDIUM="gemini-2.0-flash-exp"
GEMINI_MODEL_BASIC="gemini-2.0-flash-exp"

DB_HOST=
DB_PORT=3306
DB_DATABASE=orin_ai_crm
DB_USERNAME=
DB_PASSWORD=

ASSETS_URL="https://ai.orin.id/public"
ALLOWED_NUMBERS="+62123123123,+62111111111,+62333333333"

VPS_IP=
VPS_PORT=2181
VPS_DB_PORT=8085

# Freshchat Integration
FRESHCHAT_API_TOKEN=
FRESHCHAT_URL=
FRESHCHAT_AGENT_BEARER_TOKEN=
AGENT_ID_BOT=
FRESHCHAT_WEBHOOK_TOKEN="-----BEGIN RSA PUBLIC KEY-----examplekey-----END RSA PUBLIC KEY-----"
FRESHCHAT_ALLOWED_CHANNEL_IDS=734345,123456
FRESHCHAT_WEBHOOK_ALLOWED_IPS=10.100.102.100